rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in person can read and write only their own saga document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Future-proofing: any per-user subcollections inherit the same rule.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
