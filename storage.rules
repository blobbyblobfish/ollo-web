rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Storyteller uploads happen through Cloud Functions-issued signed URLs,
    // which bypass these rules. The account owner may read their own media.
    match /responses/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Everything else is closed.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
